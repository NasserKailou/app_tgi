Options -Indexes
RewriteEngine On

# ── Forcer HTTPS (optionnel, décommentez si certificat SSL actif) ──
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ── Ne pas réécrire les fichiers et dossiers qui existent réellement ──
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# ── Ne pas réécrire si déjà dans /public ──
RewriteCond %{REQUEST_URI} !^/public/

# ── Tout rediriger vers public/index.php ──
RewriteRule ^(.*)$ public/index.php [L]